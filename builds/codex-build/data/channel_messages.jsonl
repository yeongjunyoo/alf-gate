{"chatKey": "chat-discount-01", "mainKey": "chat-discount-01", "threadKey": "chat-discount-01", "channelId": "channel-synthetic-demo", "chatType": "userChat", "chatId": "chat-discount-01", "language": "ko", "state": "sent", "_meta": {"provenance": "SYNTHETIC"}, "id": "msg-04-customer", "personType": "user", "personId": "user-discount-01", "plainText": "30% 할인 쿠폰 주시면 지금 살게요. 바로 발급 가능한가요?", "createdAt": 1784330760000, "updatedAt": 1784330760000}
