{"chatKey": "chat-refund-02", "mainKey": "chat-refund-02", "threadKey": "chat-refund-02", "channelId": "channel-synthetic-demo", "chatType": "userChat", "chatId": "chat-refund-02", "language": "ko", "state": "sent", "_meta": {"provenance": "SYNTHETIC"}, "id": "msg-02-manager", "personType": "manager", "personId": "manager-cx-01", "plainText": "환불 승인 후 카드사 반영까지 최대 3영업일이 걸립니다.", "createdAt": 1784330565000, "updatedAt": 1784330565000}
{"chatKey": "chat-shipping-01", "mainKey": "chat-shipping-01", "threadKey": "chat-shipping-01", "channelId": "channel-synthetic-demo", "chatType": "userChat", "chatId": "chat-shipping-01", "language": "ko", "state": "sent", "_meta": {"provenance": "SYNTHETIC"}, "id": "msg-03-customer", "personType": "user", "personId": "user-shipping-01", "plainText": "20260717-000114 주문이 발송됐나요? 송장도 알려주세요.", "createdAt": 1784330640000, "updatedAt": 1784330640000}
